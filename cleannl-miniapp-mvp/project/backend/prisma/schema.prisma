// Prisma schema
// Postgres via Neon (gratis, permanente opslag — in tegenstelling tot SQLite op Render's
// gratis tier, wat bij elke deploy opnieuw begint omdat de schijf niet permanent is).

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  category    String?
  price       Float
  currency    String   @default("EUR")
  unit        String   @default("stuk")
  description String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quantities  ProductQuantity[]
  media       Media[]
}

model ProductQuantity {
  id        Int     @id @default(autoincrement())
  label     String  // bv. "2 stuks", "5 kg"
  amount    Int
  price     Float
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Media {
  id           Int      @id @default(autoincrement())
  type         String   // "image" | "video"
  url          String   // secure_url van Cloudinary
  cloudinaryId String   // public_id, nodig om later te kunnen verwijderen bij Cloudinary
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  productId    Int
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// Eén rij (singleton) met de instellingen die de bot gebruikt bij /start en de contact-knoppen.
// Bewerkbaar via het admin panel, zodat hier geen code/redeploy voor nodig is.
model BotSettings {
  id                 Int      @id @default(autoincrement())
  welcomeText        String
  logoUrl            String?
  contactTelegramUrl String?
  contactSignalUrl   String?
  contactThreemaUrl  String?
  socialInstagramUrl String?
  updatedAt          DateTime @updatedAt
}

// Iedereen die ooit met de bot heeft gepraat — gebruikt voor de gebruikerslijst en broadcasts.
model BotUser {
  id        Int      @id @default(autoincrement())
  chatId    String   @unique
  username  String?
  firstName String?
  createdAt DateTime @default(now())
}
