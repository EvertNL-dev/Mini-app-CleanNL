// Prisma schema
// Dev: SQLite (geen losse database server nodig, werkt out-of-the-box)
// Productie: verander provider naar "postgresql" en DATABASE_URL naar je Postgres connectiestring
// (bv. gratis Postgres via Render, Railway of Supabase) — de rest van het schema blijft identiek.

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  category    String?
  price       Float
  currency    String   @default("EUR")
  unit        String   @default("stuk")
  description String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quantities  ProductQuantity[]
  media       Media[]
}

model ProductQuantity {
  id        Int     @id @default(autoincrement())
  label     String  // bv. "2 stuks", "5 kg"
  amount    Int
  price     Float
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Media {
  id           Int      @id @default(autoincrement())
  type         String   // "image" | "video"
  url          String   // secure_url van Cloudinary
  cloudinaryId String   // public_id, nodig om later te kunnen verwijderen bij Cloudinary
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  productId    Int
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}
